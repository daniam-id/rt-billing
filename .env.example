# Database (dev: SQLite, prod: PostgreSQL)
DATABASE_URL="file:./dev.db"

# API Server
PORT=3001
NODE_ENV=development
JWT_SECRET="change-me-in-production-use-a-long-random-string"
JWT_EXPIRES_IN="24h"
CORS_ORIGIN="http://localhost:3000"

# Frontend (used at build time)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Set to "true" to run frontend with a fully mocked API (no backend needed).
# All API calls are intercepted and served from localStorage. Useful for demos.
NEXT_PUBLIC_DEMO_MODE="false"
